# ───────────────────────────────────────────────────────────────────────────
#  BOT DASHBOARD — environment variables (TEMPLATE — placeholders only)
#  Real values go in .env.local (git-ignored). Set the same keys in Vercel.
#  EVERYTHING here is SERVER-ONLY. None are NEXT_PUBLIC_* — secrets must never
#  reach the browser. The client talks only to our own /api route handlers.
# ───────────────────────────────────────────────────────────────────────────

# ── Supabase Management API (the "discover everything" key) ──────────────────
# One Personal Access Token discovers ALL your projects + reveals their keys.
# Create at: https://supabase.com/dashboard/account/tokens
SUPABASE_MANAGEMENT_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: restrict to specific project refs (comma-separated). Empty = all.
SUPABASE_PROJECT_ALLOWLIST=

# ── N8N (one instance hosting all customer workflows) ────────────────────────
# Use the HOST ROOT (no /api/v1, no /mcp-server). The app appends /api/v1/...
# Settings → n8n API → Create an API key
N8N_BASE_URL=https://your-instance.example.com
N8N_API_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WHAPI (token per customer/channel) ───────────────────────────────────────
# JSON map of  { "<supabase_project_ref>": "<whapi_channel_token>" }.
WHAPI_BASE_URL=https://gate.whapi.cloud
WHAPI_TOKENS_JSON={"project_ref_a":"WHAPI_TOKEN_A","project_ref_b":"WHAPI_TOKEN_B"}

# ── Auth (login gate for the dashboard) ──────────────────────────────────────
DASHBOARD_PASSWORD=change-me-to-something-strong
AUTH_SECRET=generate-a-random-32char-string-here

# ── Green API (SDR / agency WhatsApp sending) ────────────────────────────────
GREEN_API_BASE=https://api.green-api.com
GREEN_API_INSTANCE=
GREEN_API_TOKEN=

# ── Google Sheets (agency CRM source of truth) ───────────────────────────────
# Full service-account key JSON on one line; share the sheet with its email.
GOOGLE_SERVICE_ACCOUNT_JSON=
AGENCY_SHEET_ID=

# ── Google OAuth login (allowlisted emails) ──────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
AUTH_ALLOWED_EMAILS=someone@gmail.com,other@gmail.com
# Optional: force the public origin for the OAuth redirect (else auto-detected)
AUTH_BASE_URL=
